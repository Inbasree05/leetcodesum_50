class Solution {
    public int numOfPairs(String[] nums, String target) {
        HashMap<String,Integer>ans=new HashMap<>();
        int count=0;
        for(String c:nums){
            ans.put(c,ans.getOrDefault(c,0)+1);
        }
        for(String c:nums){
            if(target.startsWith(c)){
                String sub=target.substring(c.length());
                if(ans.containsKey(sub)){
                    count+=ans.get(sub);
                    if(sub.equals(c)){
                        count--;
                    }
                }
            }
        }
        return count;
    }
}
