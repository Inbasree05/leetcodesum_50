class Solution {
    public int findTheWinner(int n, int k) {
        int index=0;
        List<Integer>list=new ArrayList<>();
        for(int i=1;i<=n;i++){
            list.add(i);
        }
        while(list.size()>1){
            index=(index+k-1)%list.size();
            list.remove(index);
        }
        return list.get(0);
    }
}
