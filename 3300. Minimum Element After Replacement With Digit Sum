class Solution {
    int digitSum(int n){
        int sum=0;
        while(n>0){
        int d=n%10;
        sum+=d;
        n=n/10;
        }
        return sum;
    }
    public int minElement(int[] nums) {
        int n=nums.length;
        int m=Integer.MAX_VALUE;
        for(int i=0;i<n;i++){
            nums[i]=digitSum(nums[i]);
            m=Math.min(m,nums[i]);
        }
        return m;
    }
}
