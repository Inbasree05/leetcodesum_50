class Solution {
    public int compress(char[] chars) {
        int count;
        int i=0;
        int index=0;
        while(i<chars.length){
            char current=chars[i];
            int j=i;
            count=0;
            while(j<chars.length && chars[j]==current){
                count++;
                j++;
            }
            chars[index++]=current;
            if(count>1){
                String cnt=String.valueOf(count);
                for(char d:cnt.toCharArray()){
                    chars[index++]=d;
                }
            }
            i=j;
       }
        return index;
    }
}
