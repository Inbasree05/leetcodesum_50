class Solution {
    public int maxArea(int[] height) {
        int left=0;
        int right=height.length-1;
        int width=0;
        int heights=0;
        int area=0;
        int maxArea=Integer.MIN_VALUE;
        while(left<=right){
            width=right-left;
            heights=Math.min(height[left],height[right]);
            area=width*heights;
            maxArea=Math.max(maxArea,area);
            if(height[left]<height[right]){
                left++;
            }
            else{
                right--;
            }
        }
        return maxArea;
    }
}
