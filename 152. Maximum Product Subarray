class Solution {
    public int maxProduct(int[] nums) {
        int maxP=nums[0];
        int minP=nums[0];
        int sol=nums[0];
        for(int i=1;i<nums.length;i++){
            int t=maxP;
            maxP=Math.max(nums[i],Math.max(maxP*nums[i],minP*nums[i]));
            minP=Math.min(nums[i],Math.min(t*nums[i],minP*nums[i]));
            sol=Math.max(sol,maxP);
        }
        return sol;
    }

}
