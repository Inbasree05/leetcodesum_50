class Solution {
    public boolean isIsomorphic(String s, String t) {
        if(s.length()!=t.length()) return false;
        Map<Character,Character>st=new HashMap<>();
        Map<Character,Character>ts=new HashMap<>();
        for(int i=0;i<s.length();i++){
            char a=s.charAt(i);
            char m=t.charAt(i);
            if(st.containsKey(a)){
                if(st.get(a)!=m){
                    return false;
                }
            }
            else{
                st.put(a,m);
            }
            if(ts.containsKey(m)){
                if(ts.get(m)!=a){
                    return false;
                }
            }
            else{
                ts.put(m,a);
            }
        }
        return true;
    }
}
